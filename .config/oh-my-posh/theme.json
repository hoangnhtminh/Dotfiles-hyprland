{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "bg":      "#1a1512",
    "fg":      "#e8d5c4",
    "orange":  "#e8824a",
    "orange2": "#c4683a",
    "orange3": "#9e4e26",
    "yellow":  "#e8c24a",
    "red":     "#e85a4a",
    "green":   "#8ac44a",
    "dim":     "#7a5c45",
    "black":   "#1a1512"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:dim",
          "style": "plain",
          "template": "\u256d\u2500",
          "type": "text"
        },
        {
          "background": "p:orange",
          "foreground": "p:black",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": " <b>{{ .UserName }}</b> ",
          "trailing_diamond": "\ue0b0",
          "type": "session"
        },
        {
          "background": "p:orange2",
          "foreground": "p:black",
          "properties": {
            "display_mode": "environment",
            "home_enabled": true,
            "folder_name_fallback": false
          },
          "style": "diamond",
          "template": " <b>({{ .Venv }})</b> ",
          "trailing_diamond": "\ue0b0",
          "type": "python"
        },
        {
          "background": "p:orange3",
          "foreground": "p:fg",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "home_icon": "~"
          },
          "style": "diamond",
          "template": " ~ <b>{{ .Path }}</b> ",
          "trailing_diamond": "\ue0b0",
          "type": "path"
        },
        {
          "background": "p:yellow",
          "foreground": "p:black",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "diamond",
          "template": " <b>{{ .HEAD }}</b>{{ if .Working.Changed }} *{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "trailing_diamond": "\ue0b0",
          "type": "git"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "foreground": "p:orange2",
          "style": "plain",
          "properties": {
            "time_format": "15:04"
          },
          "template": "\uf017 <b>{{ .CurrentDate | date .Format }}</b>  ",
          "type": "time"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:dim",
          "foreground_templates": ["{{ if gt .Code 0 }}p:red{{ end }}"],
          "style": "plain",
          "template": "\u2570\u2500<p:orange><b>\u26a1</b></>  ",
          "type": "text"
        }
      ]
    }
  ],
  "transient_prompt": {
    "template": "<p:orange><b>\u26a1</b></> "
  },
  "final_space": true,
  "version": 8
}
